ISO-10303-21;
HEADER;
/* Hand-authored fixture mimicking SolidWorks-style STEP output: AP203
   CONFIG_CONTROL_DESIGN schema string, entities in reverse definition order
   (forward references throughout), spaces around '=', argument lists wrapped
   across lines, lowercase exponents, and comments inside the DATA section.
   Same tetrahedron geometry as freecad_style_tetrahedron.step. */
FILE_DESCRIPTION((''),'2;1');
FILE_NAME('tetrahedron-sw.step','2026-07-06T12:00:00',(''),(''),
  'SwSTEP 2.0','SolidWorks 2024','');
FILE_SCHEMA(('CONFIG_CONTROL_DESIGN'));
ENDSEC;
